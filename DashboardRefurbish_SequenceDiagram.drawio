          </mxGeometry>
        </mxCell>

        <!-- Swal ยืนยัน -->
        <mxCell id="m4" value="Swal ถามยืนยัน&#xa;จ่ายงาน N รายการ" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;fontSize=10;" edge="1" parent="1">
