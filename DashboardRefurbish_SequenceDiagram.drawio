        <mxCell id="m3" value="navigate → /WorkStation/{orderId}/{operationId}&#xa;พร้อม state: { current_operation, title, station }" style="html=1;verticalAlign=bottom;endArrow=block;fontSize=9;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="415" y="230" as="sourcePoint" />
            <mxPoint x="675" y="230" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="m4" value="เปิดหน้า WorkStation" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;fontSize=10;" edge="1" parent="1">
