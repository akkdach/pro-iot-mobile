            <mxPoint x="150" y="130" as="sourcePoint" />
            <mxPoint x="415" y="130" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- ตรวจ station != null -->
        <mxCell id="m2" value="ตรวจ step.station != null" style="html=1;verticalAlign=bottom;endArrow=block;dashed=1;fontSize=9;" edge="1" parent="1">
