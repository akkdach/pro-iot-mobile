        </mxCell>
        <mxCell id="m3r" value="Work Order ทั้งหมด" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;fontSize=9;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="700" y="285" as="sourcePoint" />
            <mxPoint x="415" y="285" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Divider -->
        <mxCell id="div1" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="310" as="sourcePoint" />
            <mxPoint x="760" y="310" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- stockReport → redirect -->
        <mxCell id="alt2" value="[type = stockReport]" style="text;html=1;fontSize=10;fontStyle=3;fillColor=none;strokeColor=none;" vertex="1" parent="1">
