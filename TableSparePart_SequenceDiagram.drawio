          <mxGeometry x="650" y="50" width="100" height="620" as="geometry" />
        </mxCell>

        <mxCell id="m1" value="เข้าหน้า TableSparePart&#xa;(รับ orderId จาก URL)" style="html=1;verticalAlign=bottom;endArrow=block;fontSize=10;" edge="1" parent="1">
