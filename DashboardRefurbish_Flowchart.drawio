<mxfile host="app.diagrams.net" agent="1.0" version="24.0.0">
  <diagram name="DashboardRefurbish" id="dashboard-refurbish-flow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;ระบบ Dashboard Refurbish&lt;/b&gt;&lt;br&gt;หน้า DashboardRefurbish" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="330" y="15" width="250" height="50" as="geometry" />
        </mxCell>

        <!-- Swimlane: User -->
        <mxCell id="lane_user" value="User" style="shape=table;startSize=30;container=1;collapsible=0;childLayout=tableLayout;fixedRows=1;rowLines=0;fontStyle=1;align=center;resizeLast=1;fontSize=13;swimlaneLine=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="60" y="70" width="400" height="720" as="geometry" />
        </mxCell>

        <!-- Swimlane: System -->
        <mxCell id="lane_system" value="System / API" style="shape=table;startSize=30;container=1;collapsible=0;childLayout=tableLayout;fixedRows=1;rowLines=0;fontStyle=1;align=center;resizeLast=1;fontSize=13;swimlaneLine=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="460" y="70" width="400" height="720" as="geometry" />
        </mxCell>

        <!-- ===== USER SIDE ===== -->

        <!-- เริ่มต้น -->
        <mxCell id="u_start" value="เริ่มต้น" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="120" width="120" height="45" as="geometry" />
        </mxCell>

        <!-- เข้าหน้า -->
        <mxCell id="u_enter" value="เข้าหน้า&#xa;DashboardRefurbish&#xa;(รับ step จาก state)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="190" y="195" width="140" height="55" as="geometry" />
        </mxCell>

        <!-- Decision: step type -->
        <mxCell id="u_type" value="step.type?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="210" y="310" width="100" height="70" as="geometry" />
        </mxCell>

        <!-- แสดงตาราง -->
        <mxCell id="u_table" value="แสดงตาราง Work Order&#xa;(MaterialReactTable)&#xa;+ ค้นหา + Filter SLA" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="185" y="470" width="150" height="55" as="geometry" />
        </mxCell>

        <!-- Decision: User Action -->
        <mxCell id="u_action" value="User Action?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="210" y="570" width="100" height="70" as="geometry" />
        </mxCell>

        <!-- กดเลือก row -->
        <mxCell id="u_click_row" value="กดเลือก Row&#xa;→ ไปหน้า WorkStation" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="690" width="140" height="40" as="geometry" />
        </mxCell>

        <!-- กดจ่ายงาน (Work Order List only) -->
        <mxCell id="u_dispatch" value="กดจ่ายงาน&#xa;(เฉพาะ Work Order List)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="690" width="140" height="40" as="geometry" />
        </mxCell>

        <!-- Redirect Stock -->
        <mxCell id="u_stock" value="Redirect&#xa;→ /StockReport" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="90" y="400" width="100" height="40" as="geometry" />
        </mxCell>

        <!-- ===== SYSTEM SIDE ===== -->

        <!-- Load Work Order List -->
        <mxCell id="s_load_all" value="GET /WorkOrderList&#xa;/workOrderList" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="530" y="295" width="150" height="40" as="geometry" />
        </mxCell>

        <!-- Load by Station -->
        <mxCell id="s_load_station" value="GET /WorkOrderList&#xa;/workOrderList/:station" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="295" width="150" height="40" as="geometry" />
        </mxCell>

        <!-- Filter + SLA -->
        <mxCell id="s_filter" value="Filter ข้อมูล&#xa;- ค้นหา Work Order&#xa;- กรอง SLA Status&#xa;(🟢 / 🟡 / 🔴)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="580" y="400" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- แสดงตาราง -->
        <mxCell id="s_display" value="แสดง MaterialReactTable&#xa;(SLA Timer, OrderId,&#xa;Type, Date, Equipment)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="580" y="490" width="160" height="55" as="geometry" />
        </mxCell>

        <!-- Navigate WorkStation -->
        <mxCell id="s_nav_ws" value="navigate&#xa;→ /WorkStation/:orderId/:opId&#xa;พร้อม state (station, title)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="530" y="620" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- POST StartWorkOrder -->
        <mxCell id="s_dispatch" value="วนลูป POST&#xa;/WorkOrderList/StartWorkOrder&#xa;→ จ่ายงานทีละ Order&#xa;→ Reload ข้อมูลใหม่" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="530" y="695" width="190" height="60" as="geometry" />
        </mxCell>

        <!-- ===== ARROWS ===== -->

        <!-- เริ่มต้น → เข้าหน้า -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_start" target="u_enter" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- เข้าหน้า → Decision type -->
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_enter" target="u_type" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- type → Work Order List (load all) -->
        <mxCell id="e3" value="workOrderList" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" source="u_type" target="s_load_all" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- type → Station (load by station) -->
        <mxCell id="e4" value="station&#xa;(0010-0080)" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" source="u_type" target="s_load_station" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- type → Stock Report (redirect) -->
        <mxCell id="e5" value="stockReport" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" source="u_type" target="u_stock" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Load All → Filter -->
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_load_all" target="s_filter" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Load Station → Filter -->
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_load_station" target="s_filter" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Filter → Display -->
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_filter" target="s_display" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Display → Table -->
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_display" target="u_table" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Table → Action -->
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_table" target="u_action" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Action → Click Row -->
        <mxCell id="e11" value="กดเลือก Row" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" source="u_action" target="u_click_row" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Action → Dispatch -->
        <mxCell id="e12" value="กดจ่ายงาน" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" source="u_action" target="u_dispatch" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Click Row → Navigate -->
        <mxCell id="e13" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_click_row" target="s_nav_ws" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Dispatch → POST -->
        <mxCell id="e14" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_dispatch" target="s_dispatch" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
