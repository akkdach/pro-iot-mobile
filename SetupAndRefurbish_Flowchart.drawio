        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_start" target="u_enter" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- เข้าหน้า → แสดงเมนู -->
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_enter" target="s_display" parent="1">
