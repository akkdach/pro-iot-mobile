          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- เลือก → Station -->
        <mxCell id="e6" value="Station&#xa;(0010-0080)" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" source="u_select" target="u_station" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Work Order List → Navigate -->
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_wo" target="s_navigate" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Stock Report → Navigate -->
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_stock" target="s_navigate" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Station → Navigate -->
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_station" target="s_navigate" parent="1">
