        <mxCell id="u_done" value="บันทึกสำเร็จ&#xa;→ ล้าง Cart" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="200" y="730" width="120" height="45" as="geometry" />
        </mxCell>

        <!-- ===== SYSTEM SIDE ===== -->

        <mxCell id="s_load_wc" value="GET&#xa;/Mobile/TranferRequestTo_ddl&#xa;(โหลด Work Center list)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="190" width="200" height="50" as="geometry" />
