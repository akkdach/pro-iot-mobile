        <mxCell id="s_display" value="แสดง Spare Part list&#xa;+ stock qty + ค้างเบิก&#xa;+ ปุ่ม เลือก/+/-/ลบ" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="565" y="510" width="180" height="55" as="geometry" />
        </mxCell>

        <mxCell id="s_save" value="POST /Mobile&#xa;/ReservationRequest_create&#xa;payload: { stge_loc, items[] }" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
