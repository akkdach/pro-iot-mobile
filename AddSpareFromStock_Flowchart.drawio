        <mxCell id="u_enter" value="เข้าหน้า&#xa;Add Spare From Stock" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="190" y="200" width="140" height="45" as="geometry" />
        </mxCell>

        <mxCell id="u_btn" value="กดปุ่ม 'เลือกอะไหล่'&#xa;→ เปิด Dialog" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="195" y="340" width="130" height="45" as="geometry" />
        </mxCell>

        <mxCell id="u_wc" value="เลือก Work Center&#xa;(Dropdown)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="430" width="130" height="40" as="geometry" />
        </mxCell>

        <mxCell id="u_search" value="ค้นหาอะไหล่&#xa;(Material / Desc)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="290" y="430" width="130" height="40" as="geometry" />
        </mxCell>

