          <mxGeometry x="195" y="510" width="130" height="45" as="geometry" />
        </mxCell>

        <mxCell id="u_select" value="เลือกอะไหล่&#xa;กำหนด qty (+/-)&#xa;→ เพิ่มลง Cart" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="90" y="600" width="130" height="50" as="geometry" />
