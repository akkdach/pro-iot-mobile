        <mxCell id="s_load_sp" value="GET /Mobile&#xa;/TranferRequestSparepartList&#xa;?stge_loc=WC&#xa;(โหลดอะไหล่ตาม WC)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
