        <mxCell id="s_filter" value="Filter อะไหล่ (useMemo)&#xa;ตาม keyword" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
