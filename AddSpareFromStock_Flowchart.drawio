        <mxCell id="u_save" value="กด Save&#xa;→ ยืนยัน (Swal)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="600" width="130" height="40" as="geometry" />
